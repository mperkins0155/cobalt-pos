# Cobalt POS — Environment Variables
# Copy this file to .env and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Helcim (stored in Supabase helcim_accounts table per org)
# Edge functions use SUPABASE_SERVICE_ROLE_KEY from Supabase secrets

# App
VITE_APP_NAME=Cobalt POS
VITE_APP_URL=http://localhost:5173
VITE_BASE_PATH=/

# Feature flags
VITE_ENABLE_CARD_PAYMENTS=false
VITE_ENABLE_EMAIL_RECEIPTS=false
